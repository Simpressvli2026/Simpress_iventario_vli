RewriteEngine On
RewriteCond %{REQUEST_URI} ^/api [OR]
RewriteCond %{REQUEST_URI} ^/registrar [OR]
RewriteCond %{REQUEST_URI} ^/convidado
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]
